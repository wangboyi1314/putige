# DeepSeek API（必填，用于 AI 深度解读）
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# 站点公网地址（生产必填，虎皮椒回调依赖此地址）
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# 支付模式（四选一）：
#   demo       = 演示，点击即解锁
#   qr         = 个人静态收款码，手动确认
#   xunhu      = 虎皮椒聚合支付（推荐个人，自动到账）
#   merchant   = 微信/支付宝官方商户 API（需营业执照）
PAYMENT_MODE=xunhu

# ---------- 虎皮椒 PAYMENT_MODE=xunhu ----------
# 注册: https://www.xunhupay.com/ → 支付渠道管理 → 申请签约 → 获取 APPID 与密钥
XUNHU_APP_ID=
XUNHU_APP_SECRET=
# 可选：支付宝单独渠道（不填则仅微信）
# XUNHU_ALIPAY_APP_ID=
# XUNHU_ALIPAY_APP_SECRET=
# XUNHU_API_URL=https://api.xunhupay.com/payment/do.html

# 详细步骤见 DEPLOY.md

# ---------- Umami 访问统计（可选）----------
# 注册 https://cloud.umami.is 或自建 Umami，创建网站后填入 Website ID
# NEXT_PUBLIC_ 变量需在构建时注入（Cloudflare Pages / GitHub Actions build 步骤）
NEXT_PUBLIC_UMAMI_WEBSITE_ID=
# 自建实例时改成你的脚本地址，默认用 Umami Cloud
# NEXT_PUBLIC_UMAMI_SCRIPT_URL=https://cloud.umami.is/script.js
